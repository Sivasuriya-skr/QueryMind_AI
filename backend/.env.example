# ========================================
# QueryMind AI — Backend Environment Variables
# ========================================
# Copy this file to .env and fill in your values.

# ---- Server ----
SERVER_PORT=8080

# ---- Database (app DB — stores users, connections, history, saved queries) ----
# For PostgreSQL (production):
MYSQL_URL=jdbc:postgresql://host:5432/postgres
MYSQL_USERNAME=your_db_user
MYSQL_PASSWORD=your_db_password

# ---- JWT ----
JWT_SECRET=replace-with-a-256-bit-random-base64-string
JWT_EXPIRATION=86400000

# ---- Encryption (for stored DB connection passwords) ----
ENCRYPTION_KEY=replace-with-a-random-32-byte-hex-string

# ---- CORS ----
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ---- AI Provider ----
# Options: openai, ollama, mock
AI_PROVIDER=openai

# OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1

# Ollama (when AI_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2
OLLAMA_API_URL=http://localhost:11434

# Hugging Face (when AI_PROVIDER=huggingface)
HUGGINGFACE_API_TOKEN=hf_your_token_here
HUGGINGFACE_MODEL=defog/sqlcoder-7b-2
HUGGINGFACE_API_URL=https://api-inference.huggingface.co

# Gemini (when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# ---- Rate Limiting (AI endpoints) ----
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60
